# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Passwords for the two fixed users. Must be different from each other.
HERS_PASSWORD=her-secret-password
HIS_PASSWORD=his-secret-password
ADMIN_PASSWORD=admin-secret-password

# ── Optional (defaults shown) ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./couples.db

# Base URL used to build uploaded-file URLs returned by POST /upload
BASE_URL=http://localhost:8000

# Directory where uploaded files are stored (relative to working directory)
UPLOAD_DIR=uploads

# Max upload file size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800

# Set to a JSON array to restrict CORS. Use ["*"] only in development.
# Example: ALLOWED_ORIGINS=["https://your-domain.com","http://localhost"]
ALLOWED_ORIGINS=["*"]

# Expose /docs and /redoc. Keep false in production.
ENABLE_DOCS=false

# Token lifetime in minutes (default = 30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200
